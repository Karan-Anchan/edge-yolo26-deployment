learning_material/

# ──────────────────────────────────────────────────────────────
# Large data & model artifacts (regenerate, don't commit)
# ──────────────────────────────────────────────────────────────
data/**
!data/.gitkeep

models/**
!models/.gitkeep

results/**
!results/.gitkeep

# Model / engine / dataset file types anywhere
*.pt
*.pth
*.onnx
*.engine
*.plan
*.trt
*.cache
*.weights
*.tar
*.zip
*.mp4
*.avi

# ──────────────────────────────────────────────────────────────
